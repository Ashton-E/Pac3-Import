VertexLitGeneric
{
    $basetexture "models/arctic_nvgs/skullmount/tatm_universal_diffuse"

    $bumpmap "models/arctic_nvgs/skullmount/tatm_universal_normal"
    $basemapalphaphongmask "0"
    $phong 1
    $phongfresnelranges "[0 0.5 1]"

    $envmapmask "models/arctic_nvgs/skullmount/tatm_universal_gloss"
    $envmap "env_cubemap"
    $envmaptint "[0.05 0.05 0.05]"
}