VertexLitGeneric
{
    $basetexture "models/arctic_nvgs/nvg_pvs14/pvs14_diffuse_2k"

    $bumpmap "models/arctic_nvgs/nvg_pvs14/pvs14_normal_2k"
    $basemapalphaphongmask "0"
    $phong 1
    $phongfresnelranges "[0 0.5 1]"

    $envmapmask "models/arctic_nvgs/nvg_pvs14/pvs14_gloss_2k"
    $envmap "env_cubemap"
    $envmaptint "[0.05 0.05 0.05]"
}